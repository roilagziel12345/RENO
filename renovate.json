{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separateMajorReleases",
    ":timezone(Asia/Jerusalem)"
  ],
  "labels": [
    "dependencies",
    "renovate"
  ],
  "prConcurrentLimit": 31,
  "prHourlyLimit": 31,
  "branchConcurrentLimit": 31,
  "prCreation": "immediate",
  "dependencyDashboardApproval": false,
  "rangeStrategy": "bump",
  "rebaseWhen": "behind-base-branch",
  "recreateWhen": "always",
  "automerge": false,
  "platformAutomerge": false,
  "packageRules": [
    {
      "description": "Label major updates but still open PRs in demo mode.",
      "matchUpdateTypes": ["major"],
      "labels": [
        "dependencies",
        "renovate",
        "major-update"
      ]
    }
  ]
}
