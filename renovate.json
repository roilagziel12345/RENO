{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard",
    ":semanticCommits",
    ":separateMajorReleases",
    ":timezone(Asia/Jerusalem)"
  ],
  "labels": [
    "dependencies",
    "renovate"
  ],
  "prConcurrentLimit": 31,
  "prHourlyLimit": 31,
  "branchConcurrentLimit": 31,
  "rangeStrategy": "bump",
  "rebaseWhen": "behind-base-branch",
  "automergeStrategy": "squash",
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "Group low-risk non-major npm updates.",
      "matchManagers": [
        "npm"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "npm minor and patch dependencies",
      "groupSlug": "npm-minor-patch"
    },
    {
      "description": "Group low-risk non-major Maven updates.",
      "matchManagers": [
        "maven"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "maven minor and patch dependencies",
      "groupSlug": "maven-minor-patch"
    },
    {
      "description": "Group low-risk non-major Python updates.",
      "matchManagers": [
        "pip_requirements"
      ],
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "groupName": "python minor and patch dependencies",
      "groupSlug": "python-minor-patch"
    },
    {
      "description": "Automerge patch updates after CI passes.",
      "matchUpdateTypes": [
        "patch"
      ],
      "automerge": true,
      "automergeType": "pr",
      "minimumReleaseAge": "2 days"
    },
    {
      "description": "Keep major updates isolated for client review.",
      "matchUpdateTypes": [
        "major"
      ],
      "dependencyDashboardApproval": true,
      "labels": [
        "dependencies",
        "renovate",
        "major-update"
      ]
    }
  ]
}
